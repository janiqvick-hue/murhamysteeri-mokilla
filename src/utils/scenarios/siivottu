import type { Scenario } from "../types";
import { SCENARIOS_POOL } from "./scenarios/scenariosPool";

export const SCENARIOS: Scenario[] = SCENARIOS_POOL;

export const SCENARIO_MAP: Record<string, Scenario> = Object.fromEntries(
  SCENARIOS.map((s) => [s.id, s])
);

// Arvotaan pelin alussa täysin satunnainen murhatarina mökkiläisille livenä
export function pickRandomScenario(): Scenario {
  const randomIndex = Math.floor(Math.random() * SCENARIOS.length);
  return SCENARIOS[randomIndex];
}
